{
  "name": "society-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DarshanChoudhari2022/society-maintenance-manager.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:api": "tsx apps/api/src/main.ts",
    "dev:worker": "tsx apps/worker/src/main.ts",
    "dev:web": "next dev",
    "build": "prisma generate && next build",
    "build:web": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:web": "eslint",
    "test": "npm run test:unit && npm run test:worker",
    "test:unit": "vitest run",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration",
    "test:failure": "vitest run tests/failure",
    "test:security": "vitest run tests/security",
    "test:worker": "node --import tsx --test apps/worker/src/**/*.test.ts",
    "test:e2e": "playwright test",
    "audit:gate": "node scripts/npm-audit-gate.mjs",
    "load:api": "node scripts/load/run-k6-smoke.mjs",
    "phase8:rc": "node scripts/phase8-rc-verify.mjs",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npx cap run android",
    "ci:check": "npm run lint && npm run typecheck && npm run test && npm run db:validate && npm run build",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc --noEmit -p apps/api/tsconfig.json",
    "typecheck:community-core": "tsc --noEmit -p packages/community-core/tsconfig.json",
    "typecheck:config": "tsc --noEmit -p packages/config/tsconfig.json",
    "typecheck:db": "tsc --noEmit -p packages/db/tsconfig.json",
    "typecheck:finance-core": "tsc --noEmit -p packages/finance-core/tsconfig.json",
    "typecheck:operations-core": "tsc --noEmit -p packages/operations-core/tsconfig.json",
    "typecheck:security": "tsc --noEmit -p packages/security/tsconfig.json",
    "typecheck:society-core": "tsc --noEmit -p packages/society-core/tsconfig.json",
    "typecheck:ux-core": "tsc --noEmit -p packages/ux-core/tsconfig.json",
    "typecheck:test": "tsc --noEmit -p packages/test/tsconfig.json",
    "typecheck:worker": "tsc --noEmit -p apps/worker/tsconfig.json",
    "phase2:live": "node scripts/phase2-live-validate.mjs",
    "phase1:status": "node -e \"console.log('Phase 1 foundation: compatibility workspace scaffold active')\"",
    "postinstall": "prisma generate",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:check": "node scripts/check-database-connection.mjs",
    "db:push": "prisma db push",
    "db:migrate": "npm run db:migrate:deploy",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:rls:apply": "node scripts/apply-tenant-rls.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fastify": "^5.8.5",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "server-only": "^0.0.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
