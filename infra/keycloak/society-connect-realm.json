{
  "realm": "society-connect",
  "enabled": true,
  "displayName": "Society Connect",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "otpPolicyType": "totp",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10
    }
  ],
  "clients": [
    {
      "clientId": "society-api",
      "name": "Society Connect API",
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "access.token.lifespan": "300"
      },
      "protocolMappers": [
        {
          "name": "society-membership-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "society_memberships",
            "claim.name": "society_memberships",
            "jsonType.label": "JSON",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "multivalued": "false"
          }
        },
        {
          "name": "platform-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "platform_roles",
            "claim.name": "platform_roles",
            "jsonType.label": "JSON",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "multivalued": "false"
          }
        }
      ]
    },
    {
      "clientId": "society-web",
      "name": "Society Connect Web",
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "replace-with-local-keycloak-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000"
      ],
      "attributes": {
        "access.token.lifespan": "300"
      },
      "protocolMappers": [
        {
          "name": "society-membership-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "society_memberships",
            "claim.name": "society_memberships",
            "jsonType.label": "JSON",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "multivalued": "false"
          }
        },
        {
          "name": "platform-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "platform_roles",
            "claim.name": "platform_roles",
            "jsonType.label": "JSON",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "multivalued": "false"
          }
        }
      ]
    }
  ]
}
