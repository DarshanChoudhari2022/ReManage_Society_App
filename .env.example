# Society Management local environment template
# Copy to `.env` for local development. Do not commit real secrets.

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Current Next.js app session fallback
# Use at least 32 characters in production-like environments.
SESSION_SECRET=replace-with-local-session-secret-32-chars
AUTH_SECRET=replace-with-local-auth-secret-32-chars
NEXTAUTH_SECRET=replace-with-local-nextauth-secret-32-chars

# Neon PostgreSQL / Prisma
# Use the pooled Neon URL for application traffic and the direct URL for Prisma schema commands.
# Keep sslmode=require and never commit the real credentials.
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://USER:PASSWORD@YOUR-ENDPOINT.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Optional local Docker PostgreSQL settings. These do not affect the app while DATABASE_URL points to Neon.
POSTGRES_DB=society_connect
POSTGRES_USER=society
POSTGRES_PASSWORD=society
POSTGRES_PORT=5432

# Future NestJS API
API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:4000
NEST_API_BASE_URL=http://localhost:4000

# Phase 8 BFF → NestJS shim bridge (server-side only; never expose bridge secret to browser)
API_BFF_BRIDGE_ENABLED=false
API_BFF_BRIDGE_SECRET=replace-with-local-bff-bridge-secret-32-chars
NEST_SHIM_ENABLED=false

# Future worker
WORKER_CONCURRENCY=5

# Keycloak — set KEYCLOAK_ENABLED=true only when local Keycloak is running
KEYCLOAK_ENABLED=false
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/society-connect
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/society-connect/protocol/openid-connect/certs
KEYCLOAK_REALM=society-connect
KEYCLOAK_CLIENT_ID=society-web
KEYCLOAK_CLIENT_SECRET=replace-with-local-keycloak-client-secret

# Phase 2 security foundation
API_SECURITY_HEADERS_ENABLED=true
API_AUDIT_LOGGING_ENABLED=true

# Valkey / BullMQ (distributed rate limiting + background jobs)
VALKEY_PORT=6379
VALKEY_URL=redis://localhost:6379

# PostgreSQL row-level security (apply with npm run db:rls:apply, then enable enforcement)
TENANT_RLS_ENABLED=false

# MinIO / S3-compatible storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=society-connect-local
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Web push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Email/SMS providers - intentionally blank until provider selection
EMAIL_FROM=no-reply@example.com
SMTP_URL=
SMS_PROVIDER=
SMS_API_KEY=

# Razorpay future integration
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Observability
OTEL_SERVICE_NAME=society-connect
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ---------------------------------------------------------------------------
# Production 10/10 targets (enable on staging/production only)
# ---------------------------------------------------------------------------
# TENANT_RLS_ENABLED=true          # after: npm run db:rls:apply
# API_BFF_BRIDGE_ENABLED=true
# NEST_SHIM_ENABLED=true
# Run automated gate: npm run prod:check:strict
